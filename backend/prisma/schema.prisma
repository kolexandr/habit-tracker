generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ScheduleType {
  DAILY
  WEEKLY
  CUSTOM
}

enum HabitStatus {
  ACTIVE
  ARCHIVE
}

enum HabitType {
  HEALTH
  PRODUCTIVITY
  MINDFULNESS
  FITNESS
  LEARNING
  OTHER
}

enum TemplateSource {
  PLATFORM
  USER
}

model User {
  id                String          @id @default(uuid())
  username          String          @unique
  email             String          @unique
  hashPassword      String
  productivityScore Int             @default(0)
  habits            UserHabit[]
  createdTemplates  HabitTemplate[] @relation("TemplateAuthor")
  createdAt         DateTime        @default(now())
}

model HabitTemplate {
  id              String         @id @default(uuid())
  name            String
  description     String?
  scheduleType    ScheduleType
  habitType       HabitType      @default(OTHER)
  targetPerPeriod Int            @default(1)
  endDate         DateTime?
  source          TemplateSource @default(USER)
  isPublic        Boolean        @default(true)
  createdByUserId String?
  createdByUser   User?          @relation("TemplateAuthor", fields: [createdByUserId], references: [id])
  sourceUserHabitId String?      @unique
  sourceUserHabit UserHabit?     @relation("PublishedTemplate", fields: [sourceUserHabitId], references: [id])
  createdAt       DateTime       @default(now())
  claimedHabits   UserHabit[]

  @@index([isPublic, createdAt])
}

model UserHabit {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  templateId       String?
  template         HabitTemplate?    @relation(fields: [templateId], references: [id])
  name             String
  description      String?
  scheduleType     ScheduleType
  habitType        HabitType         @default(OTHER)
  habitStatus      HabitStatus       @default(ACTIVE)
  currentStreak    Int               @default(0)
  targetPerPeriod  Int               @default(1)
  createdAt        DateTime          @default(now())
  endDate          DateTime?
  habitCompletions HabitCompletion[]
  publishedTemplate HabitTemplate?   @relation("PublishedTemplate")

  @@unique([userId, templateId])
}

model HabitCompletion {
  id          String   @id @default(uuid())
  userHabitId String
  completedAt DateTime @default(now())

  userHabit UserHabit @relation(fields: [userHabitId], references: [id])
}
